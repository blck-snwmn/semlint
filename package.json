{
  "name": "semlint",
  "version": "0.1.0",
  "description": "A lint tool that validates consistency between function/method names and their implementations",
  "main": "dist/index.js",
  "bin": {
    "semlint": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "lint": "oxlint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "tsc --noEmit && pnpm run lint && pnpm run format:check && pnpm run test"
  },
  "keywords": [
    "lint",
    "semantic",
    "function",
    "naming",
    "code-quality"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.8.1",
  "devDependencies": {
    "@biomejs/biome": "^2.0.4",
    "@types/node": "^24.0.3",
    "@vitest/coverage-v8": "^3.2.4",
    "oxlint": "^1.2.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@anthropic-ai/claude-code": "^1.0.31"
  }
}
